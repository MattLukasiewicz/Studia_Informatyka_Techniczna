generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum SessionStatus {
  IN_PROGRESS
  COMPLETED
  ABANDONED
}

enum Difficulty {
  EASY
  MEDIUM
  HARD
}

model User {
  id           String  @id @default(uuid())
  email        String  @unique
  username     String  @unique
  passwordHash String?

  bio       String?
  avatarUrl String?
  exp       Int     @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  sessions QuizSession[]
}

model QuizSession {
  id     String @id @default(uuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  status         SessionStatus @default(IN_PROGRESS)
  score          Int           @default(0)
  totalQuestions Int
  category       String?
  difficulty     Difficulty?

  startedAt DateTime  @default(now())
  endedAt   DateTime?

  results QuizResult[]

  @@index([userId])
}

model QuizResult {
  id        String      @id @default(uuid())
  sessionId String
  session   QuizSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  questionText  String
  userAnswer    String?
  correctAnswer String
  isCorrect     Boolean

  createdAt DateTime @default(now())

  @@index([sessionId])
}
