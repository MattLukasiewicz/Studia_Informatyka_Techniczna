{
	"editor.tabSize": 2,
	"editor.formatOnSave": true,
	"[typescript][javascript][json][jsonc]": {
		"editor.defaultFormatter": "biomejs.biome",
		"editor.codeActionsOnSave": {
			"source.organizeImports": "explicit"
		}
	},

	"[prisma]": {
		"editor.defaultFormatter": "Prisma.prisma"
	},

	"files.exclude": {
		"**/.git": true,
		"**/.DS_Store": true,
		"**/node_modules": true
	}
}
